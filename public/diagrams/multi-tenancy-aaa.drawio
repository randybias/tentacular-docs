<mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="Tentacular Multi-Tenancy: AAA Architecture" style="text;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fontColor=#1a1a2e;" vertex="1" parent="1">
      <mxGeometry x="300" y="20" width="500" height="40" as="geometry"/>
    </mxCell>

    <!-- Authentication Swim Lane -->
    <mxCell id="lane_auth" value="Authentication" style="swimlane;startSize=30;fillColor=#e8edf2;strokeColor=#788aa3;fontStyle=1;fontSize=13;fontColor=#1a1a2e;swimlaneLine=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="80" width="280" height="520" as="geometry"/>
    </mxCell>

    <mxCell id="user" value="User / Agent" style="shape=mxgraph.flowchart.terminator;rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="lane_auth">
      <mxGeometry x="70" y="50" width="140" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="keycloak" value="Keycloak (OIDC IdP)&#xa;Google SSO brokered" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="lane_auth">
      <mxGeometry x="40" y="150" width="200" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="jwt" value="JWT Issued&#xa;sub, email, groups" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;dashed=1;" vertex="1" parent="lane_auth">
      <mxGeometry x="55" y="270" width="170" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="bearer" value="Bearer Token&#xa;Admin / Automation" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="lane_auth">
      <mxGeometry x="55" y="380" width="170" height="50" as="geometry"/>
    </mxCell>

    <!-- Auth edges -->
    <mxCell id="e_user_kc" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;" edge="1" source="user" target="keycloak" parent="lane_auth">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e_kc_jwt" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;" edge="1" source="keycloak" target="jwt" parent="lane_auth">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Authorization Swim Lane -->
    <mxCell id="lane_authz" value="Authorization (RBAC)" style="swimlane;startSize=30;fillColor=#e8edf2;strokeColor=#788aa3;fontStyle=1;fontSize=13;fontColor=#1a1a2e;swimlaneLine=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="360" y="80" width="380" height="520" as="geometry"/>
    </mxCell>

    <mxCell id="mcp" value="MCP Server&#xa;Enforcement Point" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;shadow=1;" vertex="1" parent="lane_authz">
      <mxGeometry x="100" y="50" width="180" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="ns_layer" value="Namespace Permissions&#xa;(directory)&#xa;owner / group / mode" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="lane_authz">
      <mxGeometry x="90" y="200" width="200" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="tent_layer" value="Tentacle Permissions&#xa;(file)&#xa;owner / group / mode" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="lane_authz">
      <mxGeometry x="90" y="350" width="200" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="two_layer" value="Two-layer check:&#xa;namespace then tentacle" style="text;fontSize=10;fontStyle=2;align=center;verticalAlign=middle;fontColor=#666666;fillColor=#f8f8f8;strokeColor=#cccccc;rounded=1;" vertex="1" parent="lane_authz">
      <mxGeometry x="100" y="290" width="180" height="40" as="geometry"/>
    </mxCell>

    <mxCell id="evaluator" value="Evaluator&#xa;Rules" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;" vertex="1" parent="lane_authz">
      <mxGeometry x="10" y="120" width="80" height="50" as="geometry"/>
    </mxCell>

    <!-- Authz edges -->
    <mxCell id="e_mcp_ns" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" source="mcp" target="ns_layer" parent="lane_authz">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e_ns_tent" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" source="ns_layer" target="tent_layer" parent="lane_authz">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="e_eval_mcp" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;dashed=1;" edge="1" source="evaluator" target="mcp" parent="lane_authz">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Accounting Swim Lane -->
    <mxCell id="lane_acct" value="Accounting" style="swimlane;startSize=30;fillColor=#e8edf2;strokeColor=#788aa3;fontStyle=1;fontSize=13;fontColor=#1a1a2e;swimlaneLine=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="780" y="80" width="280" height="520" as="geometry"/>
    </mxCell>

    <mxCell id="annotations" value="Kubernetes Annotations&#xa;created-at&#xa;deployed-by&#xa;updated-at&#xa;updated-by" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="lane_acct">
      <mxGeometry x="40" y="80" width="200" height="100" as="geometry"/>
    </mxCell>

    <mxCell id="slog" value="Structured slog&#xa;Audit Logging&#xa;every authz decision logged" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="lane_acct">
      <mxGeometry x="40" y="230" width="200" height="80" as="geometry"/>
    </mxCell>

    <!-- Cross-lane edges -->

    <!-- JWT to MCP Server -->
    <mxCell id="e_jwt_mcp" value="OIDC" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;fontStyle=2;fontSize=10;" edge="1" parent="1" source="jwt" target="mcp">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="330" y="395"/>
          <mxPoint x="330" y="160"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Bearer token bypass to MCP Server -->
    <mxCell id="e_bearer_mcp" value="bypass" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;dashed=1;fontStyle=2;fontSize=10;" edge="1" parent="1" source="bearer" target="mcp">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="340" y="485"/>
          <mxPoint x="340" y="160"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- MCP to Annotations -->
    <mxCell id="e_mcp_ann" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;dashed=1;" edge="1" parent="1" source="mcp" target="annotations">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="750" y="160"/>
          <mxPoint x="750" y="210"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- MCP to slog -->
    <mxCell id="e_mcp_slog" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;dashed=1;" edge="1" parent="1" source="mcp" target="slog">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="760" y="160"/>
          <mxPoint x="760" y="380"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Kubernetes Cluster (bottom section) -->
    <mxCell id="cluster" value="Kubernetes Cluster" style="swimlane;startSize=30;fillColor=#f0f4f8;strokeColor=#788aa3;fontStyle=1;fontSize=14;fontColor=#1a1a2e;rounded=1;swimlaneLine=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="640" width="1020" height="220" as="geometry"/>
    </mxCell>

    <mxCell id="cluster_label" value="Namespaces = Tenant Boundaries" style="text;fontSize=11;fontStyle=3;align=center;verticalAlign=middle;fontColor=#788aa3;" vertex="1" parent="cluster">
      <mxGeometry x="350" y="30" width="250" height="25" as="geometry"/>
    </mxCell>

    <!-- team-alpha namespace -->
    <mxCell id="ns_alpha" value="team-alpha" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;rounded=1;" vertex="1" parent="cluster">
      <mxGeometry x="30" y="65" width="280" height="130" as="geometry"/>
    </mxCell>

    <mxCell id="t_a1" value="api-gateway" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;fontStyle=0;" vertex="1" parent="ns_alpha">
      <mxGeometry x="15" y="40" width="110" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="t_a2" value="data-pipeline" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;fontStyle=0;" vertex="1" parent="ns_alpha">
      <mxGeometry x="145" y="40" width="110" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="t_a3" value="notifier" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;fontStyle=0;" vertex="1" parent="ns_alpha">
      <mxGeometry x="15" y="85" width="110" height="35" as="geometry"/>
    </mxCell>

    <!-- team-beta namespace -->
    <mxCell id="ns_beta" value="team-beta" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;rounded=1;" vertex="1" parent="cluster">
      <mxGeometry x="360" y="65" width="280" height="130" as="geometry"/>
    </mxCell>

    <mxCell id="t_b1" value="ml-trainer" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;fontStyle=0;" vertex="1" parent="ns_beta">
      <mxGeometry x="15" y="40" width="110" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="t_b2" value="inference-svc" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;fontStyle=0;" vertex="1" parent="ns_beta">
      <mxGeometry x="145" y="40" width="110" height="35" as="geometry"/>
    </mxCell>

    <!-- system namespace -->
    <mxCell id="ns_system" value="system" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#999999;fontStyle=1;fontSize=11;rounded=1;dashed=1;" vertex="1" parent="cluster">
      <mxGeometry x="700" y="65" width="280" height="130" as="geometry"/>
    </mxCell>

    <mxCell id="sys_label" value="excluded from&#xa;tenant RBAC" style="text;fontSize=10;fontStyle=2;align=center;verticalAlign=middle;fontColor=#999999;" vertex="1" parent="ns_system">
      <mxGeometry x="80" y="45" width="120" height="40" as="geometry"/>
    </mxCell>

    <mxCell id="t_s1" value="mcp-server" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=0;" vertex="1" parent="ns_system">
      <mxGeometry x="80" y="85" width="110" height="35" as="geometry"/>
    </mxCell>

    <!-- Tentacle layer to cluster -->
    <mxCell id="e_tent_cluster" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#788aa3;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="tent_layer" target="cluster">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
