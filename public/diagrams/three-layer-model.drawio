<mxfile host="app.diagrams.net" agent="Claude Code" version="26.0.0">
  <diagram id="three-layer" name="Three-Layer Model">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Git is the System of Record" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="334" y="15" width="500" height="35" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Every tentacle starts from a scaffold and flows through three layers: Git, Disk, Kubernetes." style="text;html=1;fontSize=11;fontStyle=2;align=center;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="234" y="48" width="700" height="22" as="geometry" />
        </mxCell>

        <!-- Scaffold Quickstarts (origin) -->
        <mxCell id="scaffolds" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="250" height="160" as="geometry" />
        </mxCell>
        <mxCell id="scaffolds-title" value="Scaffold Quickstarts" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="65" y="95" width="200" height="22" as="geometry" />
        </mxCell>
        <mxCell id="scaffolds-desc" value="Production-ready templates that seed&#xa;the git layer with working code." style="text;html=1;fontSize=10;align=center;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="55" y="120" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="scaffolds-list" value="http-poller&#xa;event-processor&#xa;cron-reporter&#xa;video-pipeline (sidecar)&#xa;..." style="text;html=1;fontSize=10;align=left;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="75" y="155" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- tntc scaffold init arrow -->
        <mxCell id="scaffold-arrow" value="tntc scaffold init" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#666666;fontSize=11;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="290" y="170" as="sourcePoint" />
            <mxPoint x="370" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Layer 1: Git -->
        <mxCell id="git-layer" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="370" y="90" width="380" height="340" as="geometry" />
        </mxCell>
        <mxCell id="git-title" value="Git (System of Record)" style="text;html=1;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="440" y="95" width="240" height="25" as="geometry" />
        </mxCell>
        <mxCell id="git-desc" value="Committed state is truth. Deploy refuses dirty trees." style="text;html=1;fontSize=10;fontStyle=2;align=center;fontColor=#336600;" vertex="1" parent="1">
          <mxGeometry x="390" y="118" width="340" height="18" as="geometry" />
        </mxCell>

        <mxCell id="git-tree" value="enclaves/&#xa;  mktg-team/&#xa;    enclave.yaml&#xa;    price-monitor/&#xa;      workflow.yaml&#xa;      nodes/*.ts&#xa;      CONTEXT.md&#xa;      .secrets/*.enc.yaml&#xa;    alert-dispatcher/&#xa;  infra-alerts/&#xa;    node-health/&#xa;    uptime-check/&#xa;archive/&#xa;  old-project/" style="text;html=1;fontSize=10;align=left;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="390" y="145" width="230" height="220" as="geometry" />
        </mxCell>

        <mxCell id="git-rules" value="Commit convention:&#xa;deploy(mktg-team/price-monitor): msg&#xa;&#xa;Secrets: SOPS-encrypted in git&#xa;Archive: git mv enclaves/ --> archive/" style="text;html=1;fontSize=9;align=left;fontFamily=Courier New;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="390" y="365" width="340" height="55" as="geometry" />
        </mxCell>

        <!-- Layer 2: Disk (implied by arrows, shown as working copy) -->
        <mxCell id="disk-layer" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="370" y="460" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="disk-title" value="Disk (Working Copy)" style="text;html=1;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="440" y="465" width="240" height="25" as="geometry" />
        </mxCell>
        <mxCell id="disk-desc" value="Where the agent edits code and tests locally." style="text;html=1;fontSize=10;fontStyle=2;align=center;fontColor=#003366;" vertex="1" parent="1">
          <mxGeometry x="390" y="488" width="340" height="18" as="geometry" />
        </mxCell>
        <mxCell id="disk-tree" value="~/tentacles/&#xa;  mktg-team/price-monitor/   (edit, test)&#xa;  mktg-team/alert-dispatcher/ (edit, test)&#xa;  infra-alerts/node-health/   (edit, test)" style="text;html=1;fontSize=10;align=left;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="390" y="515" width="340" height="65" as="geometry" />
        </mxCell>
        <mxCell id="disk-note" value=".secrets.yaml lives here (plaintext) -- NEVER committed" style="text;html=1;fontSize=9;fontStyle=2;fontColor=#CC0000;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="585" width="340" height="16" as="geometry" />
        </mxCell>

        <!-- Layer 3: Kubernetes -->
        <mxCell id="k8s-layer" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="370" y="650" width="380" height="150" as="geometry" />
        </mxCell>
        <mxCell id="k8s-title" value="Kubernetes (Runtime)" style="text;html=1;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="440" y="655" width="240" height="25" as="geometry" />
        </mxCell>
        <mxCell id="k8s-desc" value="Running pods derived from committed code." style="text;html=1;fontSize=10;fontStyle=2;align=center;fontColor=#996600;" vertex="1" parent="1">
          <mxGeometry x="390" y="678" width="340" height="18" as="geometry" />
        </mxCell>
        <mxCell id="k8s-tree" value="ns:mktg-team    deploy:price-monitor  (engine+sidecar)&#xa;                deploy:alert-dispatcher (engine)&#xa;ns:infra-alerts  deploy:node-health     (engine)&#xa;                deploy:uptime-check    (engine)" style="text;html=1;fontSize=9;align=left;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="385" y="705" width="360" height="65" as="geometry" />
        </mxCell>

        <!-- Flow arrows Git <-> Disk -->
        <mxCell id="arrow-git-disk" value="git commit / git checkout" style="endArrow=classic;startArrow=classic;html=1;strokeWidth=2;strokeColor=#82b366;fontSize=10;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="430" as="sourcePoint" />
            <mxPoint x="560" y="460" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Flow arrow Disk -> K8s -->
        <mxCell id="arrow-disk-k8s" value="tntc deploy (via MCP)" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#d79b00;fontSize=10;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="620" as="sourcePoint" />
            <mxPoint x="560" y="650" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Side annotations -->
        <mxCell id="side-scaffold-note" value="Scaffolds provide the initial&#xa;workflow.yaml, nodes/*.ts,&#xa;and params.schema.yaml.&#xa;The agent customizes from there." style="text;html=1;fontSize=9;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="50" y="270" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Deploy gate callout -->
        <mxCell id="gate" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="790" y="530" width="330" height="100" as="geometry" />
        </mxCell>
        <mxCell id="gate-title" value="Deploy Gate" style="text;html=1;fontSize=12;fontStyle=1;align=center;fontColor=#CC0000;" vertex="1" parent="1">
          <mxGeometry x="880" y="535" width="160" height="20" as="geometry" />
        </mxCell>
        <mxCell id="gate-desc" value="When git-state is enabled, tntc deploy:&#xa;1. Checks for uncommitted changes&#xa;2. Refuses if working tree is dirty&#xa;3. Ensures git and disk agree before pushing to K8s" style="text;html=1;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="805" y="558" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gate-arrow" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#b85450;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="790" y="580" as="sourcePoint" />
            <mxPoint x="750" y="580" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Invariant -->
        <mxCell id="invariant" value="All three layers must agree. If they diverge, git wins." style="text;html=1;fontSize=12;fontStyle=1;align=center;fontColor=#336600;" vertex="1" parent="1">
          <mxGeometry x="334" y="810" width="500" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
